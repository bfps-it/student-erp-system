# ============================================================
# BFPS ERP Backend - Environment Variables
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control
# ============================================================

# ---------- Server ----------
NODE_ENV=development
PORT=5000
API_VERSION=v1
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---------- Database (Supabase PostgreSQL) ----------
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# ---------- Redis (Upstash) ----------
REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# ---------- JWT Authentication ----------
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Encryption (AES-256 for sensitive data) ----------
ENCRYPTION_KEY=your-32-character-encryption-key-here

# ---------- Bcrypt ----------
BCRYPT_SALT_ROUNDS=12

# ---------- Master Admin (hardcoded) ----------
MASTER_ADMIN_EMAIL=superadmin@bfpsedu.in
MASTER_ADMIN_PASSWORD=change-this-on-first-login

# ---------- Email - SMTP (Serverbyte, Outgoing) ----------
SMTP_HOST=mail.bfpsedu.in
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@bfpsedu.in
SMTP_PASS=your-smtp-password

# ---------- Email - IMAP Leave Inbox ----------
LEAVE_EMAIL_USER=leave@bfpsedu.in
LEAVE_EMAIL_PASS=your-leave-email-password
LEAVE_IMAP_HOST=mail.bfpsedu.in
LEAVE_IMAP_PORT=993

# ---------- Email - IMAP Careers Inbox ----------
CAREER_EMAIL_USER=careers@bfpsedu.in
CAREER_EMAIL_PASS=your-careers-email-password
CAREER_IMAP_HOST=mail.bfpsedu.in
CAREER_IMAP_PORT=993

# ---------- Email - IMAP Contact Inbox ----------
CONTACT_EMAIL_USER=info@bfpsedu.in
CONTACT_EMAIL_PASS=your-contact-email-password
CONTACT_IMAP_HOST=mail.bfpsedu.in
CONTACT_IMAP_PORT=993

# ---------- Email - Alert Recipients ----------
ADMIN_ALERT_EMAIL=admin@bfpsedu.in
SYSTEM_ALERT_EMAIL=system@bfpsedu.in

# ---------- Cloudinary (File Storage) ----------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---------- Razorpay (Payments) ----------
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ---------- Twilio (WhatsApp) ----------
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ---------- Firebase (Push Notifications) ----------
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ---------- Sentry (Error Tracking) ----------
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ---------- Blog Automation ----------
BLOG_AUTOMATION_KEY=your-blog-automation-api-key

# ---------- Rate Limiting ----------
RATE_LIMIT_PUBLIC=10
RATE_LIMIT_AUTH=5
RATE_LIMIT_AUTHENTICATED=200
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_EXPORT=5
